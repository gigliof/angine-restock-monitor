    "cheerio": "1.2.0",
    "dotenv": "16.6.1",
    "nodemailer": "8.0.4"
  },
  "optionalDependencies": {
    "puppeteer": "22.15.0",
    "whatsapp-web.js": "1.23.0",
    "qrcode-terminal": "0.12.0"
  },
