{
  "name": "angine-de-poitrine-restock-monitor",
  "version": "1.0.0",
  "description": "Restock monitor for anginedepoitrine.com vinyl products.",
  "main": "monitor.js",
  "scripts": {
    "start": "node monitor.js",
    "once": "node monitor.js --once",
    "test": "node --test tests/*.test.js",
    "test-notify": "node monitor.js --test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "setup-whatsapp": "npm install whatsapp-web.js qrcode-terminal",
    "audit": "npm audit"
  },
  "dependencies": {
    "axios": "1.14.0",
    "cheerio": "1.2.0",
    "dotenv": "16.6.1",
    "nodemailer": "8.0.4"
  },
  "optionalDependencies": {
    "puppeteer": "22.15.0",
    "whatsapp-web.js": "1.23.0",
    "qrcode-terminal": "0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.6.0",
    "prettier": "3.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
