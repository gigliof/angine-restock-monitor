{
  "name": "angine-de-poitrine-restock-monitor",
  "version": "1.0.0",
  "description": "Self-hosted restock monitor for anginedepoitrine.com vinyl. Notifies you the moment sold-out products come back, and optionally drives Puppeteer through checkout.",
  "main": "monitor.js",
  "scripts": {
    "start": "node monitor.js",
    "once": "node monitor.js --once",
    "test": "node --test tests/*.test.js",
    "test-notify": "node monitor.js --test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "setup-whatsapp": "npm install whatsapp-web.js qrcode-terminal",
    "audit": "npm audit",
    "prepare": "husky"
  },
  "dependencies": {
    "axios": "1.16.1",
    "cheerio": "1.2.0",
    "dotenv": "17.4.2",
    "nodemailer": "8.0.10"
  },
  "optionalDependencies": {
    "puppeteer": "25.0.4",
    "whatsapp-web.js": "1.34.7",
    "qrcode-terminal": "0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
