# ============================================================
#  RESTOCK MONITOR - Environment Variables
#  Copy this file to .env and fill in your values.
#  .env is gitignored and will NEVER be committed.
# ============================================================

# ----------------------------------------------------------
#  NOTIFICATION METHOD: "email", "whatsapp", or "telegram"
# ----------------------------------------------------------
NOTIFICATION_METHOD=email

# ----------------------------------------------------------
#  CHECK INTERVAL (minutes)
#  How often to poll. 10 min recommended.
# ----------------------------------------------------------
CHECK_INTERVAL_MINUTES=10

# ----------------------------------------------------------
#  NOTIFICATION COOLDOWN (minutes)
#  Minimum time between repeat alerts for the same product.
#  Prevents alert spam if the site flickers in/out of stock.
# ----------------------------------------------------------
NOTIFICATION_COOLDOWN_MINUTES=60

# ----------------------------------------------------------
#  EMAIL SETTINGS (required if NOTIFICATION_METHOD=email)
#
#  Gmail: use an App Password - NOT your regular password.
#  Generate one at: https://myaccount.google.com/apppasswords
#
#  SMTP presets:
#    Gmail:  smtp.gmail.com   port 587
#    iCloud: smtp.mail.me.com port 587
# ----------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
EMAIL_FROM=you@example.com
EMAIL_TO=you@example.com

# ----------------------------------------------------------
#  TELEGRAM SETTINGS (required if NOTIFICATION_METHOD=telegram)
#
#  Setup:
#    1. Message @BotFather on Telegram -> "New Bot" -> copy the token
#    2. Open a chat with your bot and send any message
#    3. Run: node monitor.js --debug-telegram
#       This verifies your token and prints your chat ID.
#    4. Set both values below and re-run --debug-telegram to confirm.
# ----------------------------------------------------------
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=123456789

# ----------------------------------------------------------
#  WHATSAPP SETTINGS (required if NOTIFICATION_METHOD=whatsapp)
#
#  IMPORTANT: WhatsApp does not deliver messages to yourself
#  (same account used to authenticate). Use a different number.
#
#  Full international format: +11234567890
#
#  WA_CHAT_ID: optional override if auto-resolution fails.
#  Run `node monitor.js --debug-wa` to find your chat ID.
# ----------------------------------------------------------
WA_RECIPIENT_NUMBER=+11234567890
# WA_CHAT_ID=11234567890@c.us

# ----------------------------------------------------------
#  CART AUTOMATION
#  Set to false to disable headless browser checkout and skip
#  the CHECKOUT_* fields below. Monitoring and notifications
#  still work normally - only the cart pre-fill is skipped.
# ----------------------------------------------------------
ENABLE_CART_AUTOMATION=true

# ----------------------------------------------------------
#  PUPPETEER SANDBOX
#  Set to true only in containerized environments (Docker, CI)
#  where Chrome sandbox cannot run. When false (default),
#  Chrome's sandbox provides an extra layer of security.
# ----------------------------------------------------------
PUPPETEER_NO_SANDBOX=false

# ----------------------------------------------------------
#  CHECKOUT DETAILS
#  Required when ENABLE_CART_AUTOMATION=true (the default).
#  Pre-filled automatically when a restock is detected.
#  Use your real shipping address here.
#
#  CHECKOUT_COUNTRY:      full country name  (e.g. Canada)
#  CHECKOUT_COUNTRY_CODE: ISO 3166-1 alpha-2 (e.g. CA)
#  CHECKOUT_STATE:        state/province name (e.g. Ontario)
#  CHECKOUT_STATE_CODE:   ISO 3166-2 code     (e.g. ON)
# ----------------------------------------------------------
CHECKOUT_EMAIL=you@example.com
CHECKOUT_FIRST_NAME=Firstname
CHECKOUT_LAST_NAME=Lastname
CHECKOUT_ADDRESS=123 Example Street
CHECKOUT_CITY=Your City
CHECKOUT_POSTAL_CODE=A1B 2C3
CHECKOUT_PHONE=+11234567890
CHECKOUT_COUNTRY=Canada
CHECKOUT_COUNTRY_CODE=CA
CHECKOUT_STATE=Ontario
CHECKOUT_STATE_CODE=ON
